@implements IDialogContentComponent<ApDrilldownDialog.Args>
@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="dlg-content">
    <p class="dlg-sub">@Content.Subtitle</p>

    <div class="chart-canvas-wrap">
        <canvas id="@_canvasId"></canvas>
    </div>

    <h4 class="dlg-section">12-month trend <span class="dlg-sub">(illustrative)</span></h4>
    <div class="chart-canvas-wrap">
        <canvas id="@_trendId"></canvas>
    </div>

    <table class="afc-table dlg-table">
        <thead>
            <tr>
                <th>Number</th>
                <th>Vendor</th>
                <th>Invoice Date</th>
                <th>Due Date</th>
                <th class="num">Amount ($)</th>
                <th>Status</th>
                <th>Age</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var inv in Content.Invoices.OrderByDescending(i => i.Amount))
            {
                <tr>
                    <td>@inv.Number</td>
                    <td>@inv.VendorName</td>
                    <td>@inv.InvoiceDate.ToString("yyyy-MM-dd")</td>
                    <td>@inv.DueDate.ToString("yyyy-MM-dd")</td>
                    <td class="num">@Fmt.Num(inv.Amount)</td>
                    <td><StatusBadge Text="@inv.Status.ToString()" Kind="@StatusKind(inv.Status)" /></td>
                    <td>@inv.AgeBucket</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter] public Args Content { get; set; } = default!;

    private readonly string _canvasId = "ap-chart-" + Guid.NewGuid().ToString("N");
    private readonly string _trendId = "trend-" + Guid.NewGuid().ToString("N");
    private bool _rendered;

    public enum ChartKind { Bar, Doughnut }

    public class Args
    {
        public string Title { get; set; } = "";
        public string Subtitle { get; set; } = "";
        public List<ApInvoice> Invoices { get; set; } = new();
        public ChartKind Kind { get; set; } = ChartKind.Bar;
        public string DatasetLabel { get; set; } = "";
        public string[] Labels { get; set; } = Array.Empty<string>();
        public decimal[] Data { get; set; } = Array.Empty<decimal>();
        public bool MoneyAxis { get; set; }
    }

    private static readonly string[] Palette =
        { "#0078d4", "#107c10", "#ca5010", "#d13438", "#8764b8", "#038387", "#a4262c", "#5c2e91", "#498205", "#c19c00" };

    private static string StatusKind(InvoiceStatus s) => s switch
    {
        InvoiceStatus.Paid => "good",
        InvoiceStatus.Overdue => "bad",
        _ => "warn"
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _rendered) return;
        _rendered = true;

        var data = Content.Data.Select(v => (double)v).ToArray();
        var isDoughnut = Content.Kind == ChartKind.Doughnut;

        object backgroundColor = isDoughnut
            ? Content.Labels.Select((_, i) => Palette[i % Palette.Length]).ToArray()
            : "#0078d4";

        object options = isDoughnut
            ? (object)new
            {
                responsive = true,
                maintainAspectRatio = false,
                plugins = new { legend = new { display = true, position = "bottom" } }
            }
            : (object)new
            {
                responsive = true,
                maintainAspectRatio = false,
                plugins = new { legend = new { display = false, position = "bottom" } },
                scales = new { y = new { beginAtZero = true } }
            };

        object config = new
        {
            type = isDoughnut ? "doughnut" : "bar",
            data = new
            {
                labels = Content.Labels,
                datasets = new[]
                {
                    new
                    {
                        label = Content.DatasetLabel,
                        data,
                        backgroundColor,
                        borderWidth = 0
                    }
                }
            },
            options
        };

        await JS.InvokeVoidAsync("afcCharts.render", _canvasId, config);

        var (tl, td) = BuildTrend();
        object trendConfig = new
        {
            type = "line",
            data = new { labels = tl, datasets = new[] { new { label = Content.DatasetLabel, data = td,
                borderColor = "#0f6cbd", backgroundColor = "#0f6cbd", borderWidth = 2, fill = false, tension = 0.3 } } },
            options = new { responsive = true, maintainAspectRatio = false,
                plugins = new { legend = new { display = false, position = "bottom" } },
                scales = new { y = new { beginAtZero = false } } }
        };
        await JS.InvokeVoidAsync("afcCharts.render", _trendId, trendConfig);
    }

    private (string[] labels, double[] data) BuildTrend()
    {
        double end = (double)Content.Data.Sum();
        if (end == 0) end = Content.Data.Length > 0 ? (double)Content.Data.Max() : 100;
        int seed = 0;
        foreach (var ch in Content.Title) seed = seed * 31 + ch;
        var rnd = new Random(seed);
        double drift = (rnd.NextDouble() - 0.45) * 0.10;
        var labels = new string[12];
        var data = new double[12];
        var start = DateTime.Now.AddMonths(-11);
        for (int m = 11; m >= 0; m--)
        {
            labels[11 - m] = start.AddMonths(11 - m).ToString("MMM");
            data[11 - m] = m == 0 ? Math.Round(end, 2)
                : Math.Round(end * (1 - drift * m) * (1 + (rnd.NextDouble() - 0.5) * 0.10), 2);
        }
        return (labels, data);
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("afcCharts.destroy", _canvasId); await JS.InvokeVoidAsync("afcCharts.destroy", _trendId); }
        catch { /* JS runtime may already be gone on teardown */ }
    }
}
