@implements IDialogContentComponent<ExecDrilldownDialog.Args>
@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="dlg-content">
    <p class="dlg-sub">@Content.Subtitle</p>

    <div class="chart-canvas-wrap">
        <canvas id="@_canvasId"></canvas>
    </div>

    <h4 class="dlg-section">12-month trend <span class="dlg-sub">(illustrative)</span></h4>
    <div class="chart-canvas-wrap">
        <canvas id="@_trendId"></canvas>
    </div>

    @if (Content.Headers.Length > 0)
    {
        <table class="afc-table dlg-table">
            <thead>
                <tr>
                    @for (int c = 0; c < Content.Headers.Length; c++)
                    {
                        <th class="@(c == 0 ? "" : "num")">@Content.Headers[c]</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Content.Rows)
                {
                    <tr>
                        @for (int c = 0; c < row.Length; c++)
                        {
                            <td class="@(c == 0 ? "" : "num")">@row[c]</td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    [Parameter] public Args Content { get; set; } = default!;

    private readonly string _canvasId = "exec-chart-" + Guid.NewGuid().ToString("N");
    private readonly string _trendId = "exec-trend-" + Guid.NewGuid().ToString("N");
    private bool _rendered;

    public enum ChartKind { Bar, Doughnut }

    public class Args
    {
        public string Title { get; set; } = "";
        public string Subtitle { get; set; } = "";
        public ChartKind Kind { get; set; } = ChartKind.Bar;
        public string DatasetLabel { get; set; } = "";
        public string[] Labels { get; set; } = Array.Empty<string>();
        public decimal[] Data { get; set; } = Array.Empty<decimal>();
        public string[] Headers { get; set; } = Array.Empty<string>();
        public List<string[]> Rows { get; set; } = new();

        /// <summary>Optional explicit 12-pt trend; if empty, one is synthesized from the headline total.</summary>
        public string[] TrendLabels { get; set; } = Array.Empty<string>();
        public decimal[] TrendData { get; set; } = Array.Empty<decimal>();
    }

    private static readonly string[] Palette =
        { "#0078d4", "#107c10", "#ca5010", "#d13438", "#8764b8", "#038387", "#a4262c", "#5c2e91", "#498205", "#c19c00" };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _rendered) return;
        _rendered = true;

        var data = Content.Data.Select(v => (double)v).ToArray();
        var isDoughnut = Content.Kind == ChartKind.Doughnut;

        object backgroundColor = isDoughnut
            ? Content.Labels.Select((_, i) => Palette[i % Palette.Length]).ToArray()
            : "#0078d4";

        object options = isDoughnut
            ? (object)new
            {
                responsive = true,
                maintainAspectRatio = false,
                plugins = new { legend = new { display = true, position = "bottom" } }
            }
            : (object)new
            {
                responsive = true,
                maintainAspectRatio = false,
                plugins = new { legend = new { display = false, position = "bottom" } },
                scales = new { y = new { beginAtZero = true } }
            };

        object config = new
        {
            type = isDoughnut ? "doughnut" : "bar",
            data = new
            {
                labels = Content.Labels,
                datasets = new[]
                {
                    new
                    {
                        label = Content.DatasetLabel,
                        data,
                        backgroundColor,
                        borderWidth = 0
                    }
                }
            },
            options
        };

        await JS.InvokeVoidAsync("afcCharts.render", _canvasId, config);

        // ---- 12-month trend (explicit if supplied, else synthesized from the headline) ----
        var (trendLabels, trendData) = BuildTrend();
        object trendConfig = new
        {
            type = "line",
            data = new
            {
                labels = trendLabels,
                datasets = new[]
                {
                    new { label = Content.DatasetLabel, data = trendData, borderColor = "#0f6cbd",
                          backgroundColor = "#0f6cbd", borderWidth = 2, fill = false, tension = 0.3 }
                }
            },
            options = new
            {
                responsive = true,
                maintainAspectRatio = false,
                plugins = new { legend = new { display = false, position = "bottom" } },
                scales = new { y = new { beginAtZero = false } }
            }
        };
        await JS.InvokeVoidAsync("afcCharts.render", _trendId, trendConfig);
    }

    private (string[] labels, double[] data) BuildTrend()
    {
        if (Content.TrendData.Length > 0)
            return (Content.TrendLabels, Content.TrendData.Select(v => (double)v).ToArray());

        // Synthesize a deterministic 12-month series ending at the headline total.
        double end = (double)Content.Data.Sum();
        if (end == 0) end = Content.Data.Length > 0 ? (double)Content.Data.Max() : 100;
        int seed = 0;
        foreach (var ch in Content.Title) seed = seed * 31 + ch;
        var rnd = new Random(seed);
        double drift = (rnd.NextDouble() - 0.45) * 0.10;   // gentle up/down bias per metric

        var labels = new string[12];
        var data = new double[12];
        var start = DateTime.Now.AddMonths(-11);
        for (int m = 11; m >= 0; m--)
        {
            labels[11 - m] = start.AddMonths(11 - m).ToString("MMM");
            data[11 - m] = m == 0 ? Math.Round(end, 2)
                : Math.Round(end * (1 - drift * m) * (1 + (rnd.NextDouble() - 0.5) * 0.10), 2);
        }
        return (labels, data);
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("afcCharts.destroy", _canvasId);
            await JS.InvokeVoidAsync("afcCharts.destroy", _trendId);
        }
        catch { /* JS runtime may already be gone on teardown */ }
    }
}
