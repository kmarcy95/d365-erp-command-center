@* Tiny zero-dependency icon set for the left nav. Single-path Tabler-style
   stroke glyphs on a 24×24 viewBox, drawn in currentColor so they inherit the
   nav link's text color. Avoids the heavy Fluent Icons package (WASM payload). *@
<svg class="nav-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
    @((MarkupString)Path(Name))
</svg>

@code {
    [Parameter] public string Name { get; set; } = "";

    private static string Path(string name) => name switch
