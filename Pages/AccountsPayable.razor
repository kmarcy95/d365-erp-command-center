@page "/accounts-payable"
@inject AppData AppData
@inject UiState Ui
@inject IJSRuntime JS
@inject IDialogService DialogService
<PageTitle>Accounts Payable · D365 ERP Command Center</PageTitle>

<div class="print-only print-header">
    <div class="ph-co">Alamo Foods Co.</div>
    <div class="ph-report">Accounts Payable — Open Invoices &amp; Aging</div>
    <div class="ph-meta">
        Fiscal period @Fiscal.PeriodLabel(AppData.Data.AsOf) · Currency @AppInfo.BaseCurrency ·
        Environment @Ui.EnvName · Generated @DateTime.Now.ToString("MMM d, yyyy h:mm tt")
    </div>
</div>

<div class="page-header">
    <div>
        <h1>Accounts Payable</h1>
        <FluentBadge Appearance="Appearance.Accent" Class="persona-badge">D365 ERP Analyst</FluentBadge>
    </div>
    <div style="display:flex;gap:.5rem;align-items:center">
        <div class="scale-toggle" role="group" aria-label="Display units">
            <button class="@(_scale == MoneyScale.Units ? "is-active" : "")" @onclick="@(() => _scale = MoneyScale.Units)">$</button>
            <button class="@(_scale == MoneyScale.Thousands ? "is-active" : "")" @onclick="@(() => _scale = MoneyScale.Thousands)">$K</button>
            <button class="@(_scale == MoneyScale.Millions ? "is-active" : "")" @onclick="@(() => _scale = MoneyScale.Millions)">$M</button>
        </div>
        <FluentButton Appearance="Appearance.Stealth" OnClick="Print">🖨 Print / PDF</FluentButton>
        <FluentButton Appearance="Appearance.Accent" OnClick="Export">⬇ Export CSV</FluentButton>
    </div>
</div>

<PageMeta AsOf="@AppData.Data.AsOf" GeneratedAtUtc="@AppData.Data.GeneratedAtUtc" Module="Accounts payable" />

@if (_error)
{
    <ErrorBanner Message="Couldn't load accounts payable. Use the account menu in the header to reset the demo data." />
}
else if (!_ready)
{
    <Skeleton Variant="page" />
}
else
{
    <div class="kpi-grid">
        <KpiCard Label="Outstanding Payable" Value="@Fmt.Money(_outstanding)" Sub="Open + overdue invoices"
                 Clickable="true" OnClick="ShowOutstanding" />
        <KpiCard Label="Overdue" Value="@Fmt.Money(_overdueValue)" Sub="Past due date" Positive="false"
                 Clickable="true" OnClick="ShowOverdue" />
        <KpiCard Label="Open Invoices" Value="@Fmt.Num(_openCount)" Sub="Not yet paid"
                 Clickable="true" OnClick="ShowByStatus" />
        <KpiCard Label="Vendors" Value="@Fmt.Num(_vendorCount)" Sub="With open balances"
                 Clickable="true" OnClick="ShowVendors" />
    </div>

    <div class="chart-grid">
        <Chart Title="Outstanding payable by aging bucket" Type="bar" Labels="@_agingLabels" Series="@_agingSeries" />
    </div>

    <FluentSearch @bind-Value="_search" @bind-Value:after="Apply" Placeholder="Search vendor name or number…" Class="afc-search" />

    <p class="grid-hint">Click any row for the invoice detail.</p>
    <div class="grid-wrap">
        <FluentDataGrid Items="@_filtered" Pagination="@_pagination" TGridItem="ApInvoice"
                        OnRowClick="@(async (FluentDataGridRow<ApInvoice> row) => await OpenInvoice(row.Item))"
                        RowClass="@(_ => "grid-row-clickable")">
            <PropertyColumn Property="@(i => i.Number)" Title="Number" Sortable="true" />
            <PropertyColumn Property="@(i => i.VendorName)" Title="Vendor" Sortable="true" />
            <PropertyColumn Property="@(i => i.InvoiceDate)" Title="Invoice Date" Sortable="true"
                            IsDefaultSortColumn="true" InitialSortDirection="SortDirection.Descending" />
            <PropertyColumn Property="@(i => i.DueDate)" Title="Due Date" Sortable="true" />
            <PropertyColumn Property="@(i => i.Amount)" Format="N0" Title="Amount ($)" Sortable="true" Align="Align.End" />
            <PropertyColumn Property="@(i => i.AgeDays)" Format="N0" Title="Age (days)" Sortable="true" Align="Align.End" />
            <PropertyColumn Property="@(i => i.AgeBucket)" Title="Bucket" Sortable="true" />
            <TemplateColumn Title="Status" Sortable="false">
                <StatusBadge Text="@context.Status.ToString()" Kind="@StatusKind(context.Status)" />
            </TemplateColumn>
            <TemplateColumn Title="Approval" Sortable="false">
                <StatusBadge Text="@context.ApprovalStatus" Kind="@(context.ApprovalStatus == "Approved" ? "good" : "warn")" />
            </TemplateColumn>
        </FluentDataGrid>
    </div>

    <FluentPaginator State="@_pagination" />
}

@code {
    private bool _ready;
    private string _search = "";

    private List<ApInvoice> _all = new();
    private IQueryable<ApInvoice> _filtered = Enumerable.Empty<ApInvoice>().AsQueryable();
    private readonly PaginationState _pagination = new() { ItemsPerPage = 15 };

    private decimal _outstanding;
    private decimal _overdueValue;
    private int _openCount;
    private int _vendorCount;

    // Aging buckets in display order.
    private static readonly string[] BucketOrder = { "Current", "1-30", "31-60", "61-90", "90+" };

    private string[] _agingLabels = Array.Empty<string>();
    private List<ChartSeries> _agingSeries = new();

    private static string StatusKind(InvoiceStatus s) => s switch
    {
        InvoiceStatus.Paid => "good",
        InvoiceStatus.Overdue => "bad",
        _ => "warn"
    };

    private List<ApInvoice> OpenInvoices => _all.Where(i => i.Status != InvoiceStatus.Paid).ToList();

    protected override async Task OnInitializedAsync()
    {
        await AppData.InitializeAsync();
        _all = AppData.Data.ApInvoices.ToList();

        var open = OpenInvoices;
        _outstanding = open.Sum(i => i.Amount);
        _overdueValue = _all.Where(i => i.Status == InvoiceStatus.Overdue).Sum(i => i.Amount);
        _openCount = open.Count;
        _vendorCount = open.Select(i => i.VendorNumber).Distinct().Count();

        _agingLabels = BucketOrder;
        _agingSeries = new List<ChartSeries>
        {
            new ChartSeries("Outstanding ($)",
                BucketOrder.Select(b => (double)open.Where(i => i.AgeBucket == b).Sum(i => i.Amount)).ToArray())
        };

        Apply();
        _ready = true;
    }

    private void Apply()
    {
        var q = _all.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(_search))
        {
            var s = _search.Trim();
            q = q.Where(i =>
                i.VendorName.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                i.VendorNumber.Contains(s, StringComparison.OrdinalIgnoreCase));
        }
        _filtered = q.AsQueryable();
    }

    // ---------------- Drill-down dialogs ----------------

    private async Task ShowDrilldown(ApDrilldownDialog.Args args)
    {
        var parameters = new DialogParameters
        {
            Title = args.Title,
            Width = "820px",
            PrimaryAction = "Close",
            SecondaryAction = null
        };
        await DialogService.ShowDialogAsync<ApDrilldownDialog>(args, parameters);
    }

    private async Task ShowOutstanding()
    {
        var open = OpenInvoices;
        var data = BucketOrder.Select(b => open.Where(i => i.AgeBucket == b).Sum(i => i.Amount)).ToArray();
        await ShowDrilldown(new ApDrilldownDialog.Args
        {
            Title = "Outstanding Payable by Aging Bucket",
            Subtitle = $"{Fmt.Money(_outstanding)} outstanding across {open.Count} open invoices.",
            Invoices = open,
            Kind = ApDrilldownDialog.ChartKind.Bar,
            DatasetLabel = "Outstanding ($)",
            Labels = BucketOrder,
            Data = data,
            MoneyAxis = true
        });
    }

    private async Task ShowOverdue()
    {
        var overdue = _all.Where(i => i.Status == InvoiceStatus.Overdue).ToList();
        var buckets = BucketOrder.Where(b => b != "Current").ToArray();
        var data = buckets.Select(b => overdue.Where(i => i.AgeBucket == b).Sum(i => i.Amount)).ToArray();
        await ShowDrilldown(new ApDrilldownDialog.Args
        {
            Title = "Overdue Payable by Aging Bucket",
            Subtitle = $"{Fmt.Money(_overdueValue)} overdue across {overdue.Count} invoices.",
            Invoices = overdue,
            Kind = ApDrilldownDialog.ChartKind.Bar,
            DatasetLabel = "Overdue ($)",
            Labels = buckets,
            Data = data,
            MoneyAxis = true
        });
    }

    private async Task ShowByStatus()
    {
        var open = OpenInvoices;
        var groups = open.GroupBy(i => i.Status).OrderBy(g => g.Key).ToList();
        await ShowDrilldown(new ApDrilldownDialog.Args
        {
            Title = "Open Invoices by Status",
            Subtitle = $"{open.Count} open invoices worth {Fmt.Money(_outstanding)}.",
            Invoices = open,
            Kind = ApDrilldownDialog.ChartKind.Doughnut,
            DatasetLabel = "Invoices",
            Labels = groups.Select(g => g.Key.ToString()).ToArray(),
            Data = groups.Select(g => (decimal)g.Count()).ToArray()
        });
    }

    private async Task ShowVendors()
    {
        var open = OpenInvoices;
        var top = open.GroupBy(i => i.VendorName)
            .Select(g => new { Name = g.Key, Value = g.Sum(i => i.Amount) })
            .OrderByDescending(x => x.Value)
            .Take(10)
            .ToList();
        await ShowDrilldown(new ApDrilldownDialog.Args
        {
            Title = "Top Vendors by Outstanding Payable",
            Subtitle = $"{_vendorCount} vendors with open balances; showing the top {top.Count}.",
            Invoices = open,
            Kind = ApDrilldownDialog.ChartKind.Bar,
            DatasetLabel = "Outstanding ($)",
            Labels = top.Select(x => x.Name).ToArray(),
            Data = top.Select(x => x.Value).ToArray(),
            MoneyAxis = true
        });
    }

    private async Task OpenInvoice(ApInvoice? inv)
    {
        if (inv is null) return;
        var parameters = new DialogParameters
        {
            Title = $"Invoice {inv.Number}",
            Width = "560px",
            PrimaryAction = "Close",
            SecondaryAction = null
        };
        await DialogService.ShowDialogAsync<ApInvoiceDetailDialog>(inv, parameters);
    }

    private async Task Export()
    {
        var headers = new[] { "Number", "Vendor Number", "Vendor Name", "Invoice Date", "Due Date", "Amount", "Status", "Approval Status", "Age Days", "Age Bucket" };
        var rows = _all.Select(i => new[]
        {
            i.Number,
            i.VendorNumber,
            i.VendorName,
            i.InvoiceDate.ToString("yyyy-MM-dd"),
            i.DueDate.ToString("yyyy-MM-dd"),
            i.Amount.ToString("0.##"),
            i.Status.ToString(),
            i.ApprovalStatus,
            i.AgeDays.ToString(),
            i.AgeBucket
        });
        var csv = Csv.Build(headers, rows);
        await JS.InvokeVoidAsync("afcDownload", "accounts-payable.csv", csv);
    }
}
