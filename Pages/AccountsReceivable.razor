@page "/accounts-receivable"
@inject AppData AppData
@inject IJSRuntime JS
@inject IDialogService DialogService
<PageTitle>Accounts Receivable · D365 ERP Command Center</PageTitle>

<div class="page-header">
    <div>
        <h1>Accounts Receivable</h1>
        <FluentBadge Appearance="Appearance.Accent" Class="persona-badge">D365 ERP Analyst</FluentBadge>
    </div>
    <FluentButton Appearance="Appearance.Accent" OnClick="Export">Export CSV</FluentButton>
</div>

<PageMeta AsOf="@AppData.Data.AsOf" GeneratedAtUtc="@AppData.Data.GeneratedAtUtc" Module="Accounts receivable" />

@if (!_ready)
{
    <Skeleton Variant="page" />
}
else
{
    <div class="kpi-grid">
        <KpiCard Label="Outstanding Receivable" Value="@Fmt.Money(_outstanding)" Sub="Open + overdue invoices"
                 Clickable="true" OnClick="ShowOutstanding" />
        <KpiCard Label="Overdue" Value="@Fmt.Money(_overdueValue)" Sub="Past due date" Positive="false"
                 Clickable="true" OnClick="ShowOverdue" />
        <KpiCard Label="In Collections" Value="@Fmt.Num(_inCollections)" Sub="Escalated invoices" Positive="false"
                 Clickable="true" OnClick="ShowCollections" />
        <KpiCard Label="Customers" Value="@Fmt.Num(_customerCount)" Sub="With open balances"
                 Clickable="true" OnClick="ShowCustomers" />
    </div>

    <div class="chart-grid">
        <Chart Title="Outstanding receivable by aging bucket" Type="bar" Labels="@_agingLabels" Series="@_agingSeries" />
    </div>

    <FluentSearch @bind-Value="_search" @bind-Value:after="Apply" Placeholder="Search customer name or number…" Class="afc-search" />

    <p class="grid-hint">Click any row for the invoice detail.</p>
    <div class="grid-wrap">
        <FluentDataGrid Items="@_filtered" Pagination="@_pagination" TGridItem="ArInvoice"
                        OnRowClick="@(async (FluentDataGridRow<ArInvoice> row) => await OpenInvoice(row.Item))"
                        RowClass="@(_ => "grid-row-clickable")">
            <PropertyColumn Property="@(i => i.Number)" Title="Number" Sortable="true" />
            <PropertyColumn Property="@(i => i.CustomerName)" Title="Customer" Sortable="true" />
            <PropertyColumn Property="@(i => i.Segment)" Title="Segment" Sortable="true" />
            <PropertyColumn Property="@(i => i.InvoiceDate)" Title="Invoice Date" Sortable="true"
                            IsDefaultSortColumn="true" InitialSortDirection="SortDirection.Descending" />
            <PropertyColumn Property="@(i => i.DueDate)" Title="Due Date" Sortable="true" />
            <PropertyColumn Property="@(i => i.Amount)" Format="N0" Title="Amount ($)" Sortable="true" Align="Align.End" />
            <PropertyColumn Property="@(i => i.AgeBucket)" Title="Bucket" Sortable="true" />
            <TemplateColumn Title="Status" Sortable="false">
                <StatusBadge Text="@context.Status.ToString()" Kind="@StatusKind(context.Status)" />
            </TemplateColumn>
            <TemplateColumn Title="Collection" Sortable="false">
                <StatusBadge Text="@context.CollectionStatus" Kind="@CollectionKind(context.CollectionStatus)" />
            </TemplateColumn>
        </FluentDataGrid>
    </div>

    <FluentPaginator State="@_pagination" />
}

@code {
    private bool _ready;
    private string _search = "";

    private List<ArInvoice> _all = new();
    private IQueryable<ArInvoice> _filtered = Enumerable.Empty<ArInvoice>().AsQueryable();
    private readonly PaginationState _pagination = new() { ItemsPerPage = 15 };

    private decimal _outstanding;
    private decimal _overdueValue;
    private int _inCollections;
    private int _customerCount;

    private static readonly string[] BucketOrder = { "Current", "1-30", "31-60", "61-90", "90+" };

    private string[] _agingLabels = Array.Empty<string>();
    private List<ChartSeries> _agingSeries = new();

    private static string StatusKind(InvoiceStatus s) => s switch
    {
        InvoiceStatus.Paid => "good",
        InvoiceStatus.Overdue => "bad",
        _ => "warn"
    };

    private static string CollectionKind(string c) => c switch
    {
        "In Collections" => "bad",
        "Reminded" => "warn",
        _ => "good"
    };

    private List<ArInvoice> OpenInvoices => _all.Where(i => i.Status != InvoiceStatus.Paid).ToList();

    protected override async Task OnInitializedAsync()
    {
        await AppData.InitializeAsync();
        _all = AppData.Data.ArInvoices.ToList();

        var open = OpenInvoices;
        _outstanding = open.Sum(i => i.Amount);
        _overdueValue = _all.Where(i => i.Status == InvoiceStatus.Overdue).Sum(i => i.Amount);
        _inCollections = _all.Count(i => i.CollectionStatus == "In Collections");
        _customerCount = open.Select(i => i.CustomerNumber).Distinct().Count();

        _agingLabels = BucketOrder;
        _agingSeries = new List<ChartSeries>
        {
            new ChartSeries("Outstanding ($)",
                BucketOrder.Select(b => (double)open.Where(i => i.AgeBucket == b).Sum(i => i.Amount)).ToArray())
        };

        Apply();
        _ready = true;
    }

    private void Apply()
    {
        var q = _all.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(_search))
        {
            var s = _search.Trim();
            q = q.Where(i =>
                i.CustomerName.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                i.CustomerNumber.Contains(s, StringComparison.OrdinalIgnoreCase));
        }
        _filtered = q.AsQueryable();
    }

    // ---------------- Drill-down dialogs ----------------

    private async Task ShowDrilldown(ArDrilldownDialog.Args args)
    {
        var parameters = new DialogParameters
        {
            Title = args.Title,
            Width = "820px",
            PrimaryAction = "Close",
            SecondaryAction = null
        };
        await DialogService.ShowDialogAsync<ArDrilldownDialog>(args, parameters);
    }

    private async Task ShowOutstanding()
    {
        var open = OpenInvoices;
        var data = BucketOrder.Select(b => open.Where(i => i.AgeBucket == b).Sum(i => i.Amount)).ToArray();
        await ShowDrilldown(new ArDrilldownDialog.Args
        {
            Title = "Outstanding Receivable by Aging Bucket",
            Subtitle = $"{Fmt.Money(_outstanding)} outstanding across {open.Count} open invoices.",
            Invoices = open,
            Kind = ArDrilldownDialog.ChartKind.Bar,
            DatasetLabel = "Outstanding ($)",
            Labels = BucketOrder,
            Data = data,
            MoneyAxis = true
        });
    }

    private async Task ShowOverdue()
    {
        var overdue = _all.Where(i => i.Status == InvoiceStatus.Overdue).ToList();
        var buckets = BucketOrder.Where(b => b != "Current").ToArray();
        var data = buckets.Select(b => overdue.Where(i => i.AgeBucket == b).Sum(i => i.Amount)).ToArray();
        await ShowDrilldown(new ArDrilldownDialog.Args
        {
            Title = "Overdue Receivable by Aging Bucket",
            Subtitle = $"{Fmt.Money(_overdueValue)} overdue across {overdue.Count} invoices.",
            Invoices = overdue,
            Kind = ArDrilldownDialog.ChartKind.Bar,
            DatasetLabel = "Overdue ($)",
            Labels = buckets,
            Data = data,
            MoneyAxis = true
        });
    }

    private async Task ShowCollections()
    {
        var coll = _all.Where(i => i.CollectionStatus == "In Collections").ToList();
        var groups = coll.GroupBy(i => i.Segment).OrderByDescending(g => g.Sum(i => i.Amount)).ToList();
        await ShowDrilldown(new ArDrilldownDialog.Args
        {
            Title = "Invoices In Collections",
            Subtitle = $"{coll.Count} invoices in collections worth {Fmt.Money(coll.Sum(i => i.Amount))}, by segment.",
            Invoices = coll,
            Kind = ArDrilldownDialog.ChartKind.Bar,
            DatasetLabel = "In collections ($)",
            Labels = groups.Select(g => g.Key).ToArray(),
            Data = groups.Select(g => g.Sum(i => i.Amount)).ToArray(),
            MoneyAxis = true
        });
    }

    private async Task ShowCustomers()
    {
        var open = OpenInvoices;
        var top = open.GroupBy(i => i.CustomerName)
            .Select(g => new { Name = g.Key, Value = g.Sum(i => i.Amount) })
            .OrderByDescending(x => x.Value)
            .Take(10)
            .ToList();
        await ShowDrilldown(new ArDrilldownDialog.Args
        {
            Title = "Top Customers by Outstanding Receivable",
            Subtitle = $"{_customerCount} customers with open balances; showing the top {top.Count}.",
            Invoices = open,
            Kind = ArDrilldownDialog.ChartKind.Bar,
            DatasetLabel = "Outstanding ($)",
            Labels = top.Select(x => x.Name).ToArray(),
            Data = top.Select(x => x.Value).ToArray(),
            MoneyAxis = true
        });
    }

    private async Task OpenInvoice(ArInvoice? inv)
    {
        if (inv is null) return;
        var parameters = new DialogParameters
        {
            Title = $"Invoice {inv.Number}",
            Width = "560px",
            PrimaryAction = "Close",
            SecondaryAction = null
        };
        await DialogService.ShowDialogAsync<ArInvoiceDetailDialog>(inv, parameters);
    }

    private async Task Export()
    {
        var headers = new[] { "Number", "Customer Number", "Customer Name", "Segment", "Invoice Date", "Due Date", "Amount", "Status", "Collection Status", "Age Days", "Age Bucket" };
        var rows = _all.Select(i => new[]
        {
            i.Number,
            i.CustomerNumber,
            i.CustomerName,
            i.Segment,
            i.InvoiceDate.ToString("yyyy-MM-dd"),
            i.DueDate.ToString("yyyy-MM-dd"),
            i.Amount.ToString("0.##"),
            i.Status.ToString(),
            i.CollectionStatus,
            i.AgeDays.ToString(),
            i.AgeBucket
        });
        var csv = Csv.Build(headers, rows);
        await JS.InvokeVoidAsync("afcDownload", "accounts-receivable.csv", csv);
    }
}
