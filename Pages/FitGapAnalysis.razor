@page "/fit-gap"
@inject AppData AppData
@inject UiState Ui
@inject IJSRuntime JS
@inject IDialogService DialogService
<PageTitle>Fit-Gap Analysis · D365 ERP Command Center</PageTitle>

<div class="print-only print-header">
    <div class="ph-co">Alamo Foods Co.</div>
    <div class="ph-report">Fit-Gap Analysis — Requirements vs. standard D365 F&amp;O</div>
    <div class="ph-meta">
        As of @AppData.Data.AsOf.ToString("MMM d, yyyy") · Environment @Ui.EnvName ·
        Generated @DateTime.Now.ToString("MMM d, yyyy h:mm tt")
    </div>
</div>

<div class="page-header">
    <div>
        <h1>Fit-Gap Analysis</h1>
        <FluentBadge Appearance="Appearance.Accent" Class="persona-badge">Business Analyst</FluentBadge>
    </div>
    <div style="display:flex;gap:.5rem;align-items:center">
        <FluentButton Appearance="Appearance.Stealth" OnClick="Print">🖨 Print / PDF</FluentButton>
        <FluentButton Appearance="Appearance.Accent" OnClick="Export">⬇ Export CSV</FluentButton>
    </div>
</div>

<PageMeta AsOf="@AppData.Data.AsOf" GeneratedAtUtc="@AppData.Data.GeneratedAtUtc" Module="Implementation · Fit-gap" />

@if (_error)
{
    <ErrorBanner Message="Couldn't load the fit-gap analysis. Use the account menu in the header to reset the demo data." />
}
else if (!_ready)
{
    <Skeleton Variant="page" />
}
else
{
    <div class="kpi-grid">
        <KpiCard Label="Requirements" Value="@Fmt.Num(_reqs.Count)" Sub="Total catalogued"
                 Clickable="true" OnClick="@(() => ShowFit(null, "All requirements"))" />
        <KpiCard Label="Fit %" Value="@Fmt.Pct(_fitPct)" Sub="Standard + configuration"
                 Clickable="true" OnClick="ShowFitBreakdown" />
        <KpiCard Label="Customizations" Value="@Fmt.Num(_custom)" Sub="Custom development" Positive="false"
                 Clickable="true" OnClick="@(() => ShowFit(FitGap.Customization, "Customizations"))" />
        <KpiCard Label="Total Effort" Value="@($"{_totalEffort:#,0} days")" Sub="Configuration + build estimate"
                 Clickable="true" OnClick="ShowEffort" />
    </div>

    <div class="chart-grid">
        <Chart Title="Fit-gap distribution" Type="doughnut" Labels="@_fitLabels" Series="@_fitSeries"
               Hint="Click a slice to filter the table by category" OnLabelClick="OnFitPick" />
        <Chart Title="Effort by area (days)" Type="bar" Labels="@_areaLabels" Series="@_areaSeries"
               Hint="Click a bar to filter the table by area" OnLabelClick="OnAreaPick" />
    </div>

    <div class="filter-bar">
        <div class="filter-field">
            <label>Area</label>
            <select value="@_area" @onchange="@(e => { _area = e.Value?.ToString() ?? ""; Apply(); })">
                <option value="">All areas</option>
                @foreach (var a in _areas) { <option value="@a">@a</option> }
            </select>
        </div>
        <div class="filter-field">
            <label>Priority</label>
            <select value="@_priority" @onchange="@(e => { _priority = e.Value?.ToString() ?? ""; Apply(); })">
                <option value="">All</option>
                <option value="Must">Must</option>
                <option value="Should">Should</option>
                <option value="Could">Could</option>
            </select>
        </div>
        <div class="filter-field">
            <label>Fit-Gap</label>
            <select value="@_fit" @onchange="@(e => { _fit = e.Value?.ToString() ?? ""; Apply(); })">
                <option value="">All</option>
                @foreach (var f in Enum.GetNames<FitGap>()) { <option value="@f">@f</option> }
            </select>
        </div>
        <div class="filter-field">
            <label>Process</label>
            <select value="@_process" @onchange="@(e => { _process = e.Value?.ToString() ?? ""; Apply(); })">
                <option value="">All</option>
                @foreach (var p in _processes) { <option value="@p">@p</option> }
            </select>
        </div>
        <div class="filter-field" style="flex:1 1 180px">
            <label>Search</label>
            <input value="@_search" @oninput="@(e => { _search = e.Value?.ToString() ?? ""; Apply(); })" placeholder="Code or description…" />
        </div>
        <button class="fb-reset" @onclick="ResetFilters">Reset filters</button>
    </div>

    <p class="grid-hint">@_filteredCount of @_reqs.Count requirements shown · click any requirement for its rationale and linked test cases.</p>

    @if (_filteredCount == 0)
    {
        <div class="grid-wrap">
            <EmptyState Emoji="🧩" Title="No matching requirements"
                        Message="No requirements match the current filters. Try clearing a filter or resetting." />
        </div>
    }
    else
    {
        <div class="grid-wrap">
            <FluentDataGrid Items="@_filtered" Pagination="@_pagination" TGridItem="Requirement"
                            OnRowClick="@(async (FluentDataGridRow<Requirement> row) => await OpenRequirement(row.Item))"
                            RowClass="@(_ => "grid-row-clickable")">
                <PropertyColumn Property="@(r => r.Code)" Title="Code" Sortable="true" />
                <PropertyColumn Property="@(r => r.Area)" Title="Area" Sortable="true" />
                <PropertyColumn Property="@(r => r.Description)" Title="Description" />
                <PropertyColumn Property="@(r => r.Priority)" Title="Priority" Sortable="true" />
                <PropertyColumn Property="@(r => r.ProcessArea)" Title="Process" Sortable="true" />
                <TemplateColumn Title="Fit-Gap" Sortable="true">
                    <StatusBadge Text="@context.FitGap.ToString()" Kind="@FitGapKind(context.FitGap)" />
                </TemplateColumn>
                <PropertyColumn Property="@(r => r.EffortDays)" Title="Effort (days)" Sortable="true" Align="Align.End" />
            </FluentDataGrid>
        </div>
        <FluentPaginator State="@_pagination" />
    }
}

@code {
    private bool _ready;
    private bool _error;
    private string _search = "", _area = "", _priority = "", _fit = "", _process = "";

    private List<Requirement> _reqs = new();
    private IQueryable<Requirement> _filtered = Enumerable.Empty<Requirement>().AsQueryable();
    private int _filteredCount;
    private readonly PaginationState _pagination = new() { ItemsPerPage = 15 };

    private decimal _fitPct;
    private int _custom, _isv, _standard, _config;
    private int _totalEffort;

    private string[] _areas = Array.Empty<string>();
    private string[] _processes = Array.Empty<string>();

    private string[] _fitLabels = Array.Empty<string>();
    private List<ChartSeries> _fitSeries = new();
    private string[] _areaLabels = Array.Empty<string>();
    private List<ChartSeries> _areaSeries = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await AppData.InitializeAsync();
            _reqs = AppData.Data.Requirements.ToList();

            int total = _reqs.Count;
            _standard = _reqs.Count(r => r.FitGap == FitGap.Standard);
            _config = _reqs.Count(r => r.FitGap == FitGap.Configuration);
            _custom = _reqs.Count(r => r.FitGap == FitGap.Customization);
            _isv = _reqs.Count(r => r.FitGap == FitGap.ISV);
            _fitPct = total == 0 ? 0m : (decimal)(_standard + _config) / total * 100m;
            _totalEffort = _reqs.Sum(r => r.EffortDays);

            _areas = _reqs.Select(r => r.Area).Distinct().OrderBy(a => a).ToArray();
            _processes = _reqs.Select(r => r.ProcessArea).Distinct().OrderBy(p => p).ToArray();

            _fitLabels = new[] { "Standard", "Configuration", "Customization", "ISV" };
            _fitSeries = new List<ChartSeries>
            {
                new ChartSeries("Requirements", new double[] { _standard, _config, _custom, _isv })
            };

            var byArea = _areas
                .Select(a => new { Area = a, Effort = _reqs.Where(r => r.Area == a).Sum(r => r.EffortDays) })
                .OrderByDescending(x => x.Effort).ToList();
            _areaLabels = byArea.Select(x => x.Area).ToArray();
            _areaSeries = new List<ChartSeries> { new ChartSeries("Effort (days)", byArea.Select(x => (double)x.Effort).ToArray()) };

            Apply();
            _ready = true;
        }
        catch
        {
            _error = true;
        }
    }

    private void ResetFilters() { _search = _area = _priority = _fit = _process = ""; Apply(); }

    // Chart→table toggles
    private void OnFitPick(string f) { _fit = _fit == f ? "" : f; Apply(); }
    private void OnAreaPick(string a) { _area = _area == a ? "" : a; Apply(); }

    private void Apply()
    {
        var q = _reqs.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(_area)) q = q.Where(r => r.Area == _area);
        if (!string.IsNullOrWhiteSpace(_priority)) q = q.Where(r => r.Priority == _priority);
        if (!string.IsNullOrWhiteSpace(_fit)) q = q.Where(r => r.FitGap.ToString() == _fit);
        if (!string.IsNullOrWhiteSpace(_process)) q = q.Where(r => r.ProcessArea == _process);
        if (!string.IsNullOrWhiteSpace(_search))
        {
            var s = _search.Trim();
            q = q.Where(r => r.Code.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                             r.Description.Contains(s, StringComparison.OrdinalIgnoreCase));
        }
        var list = q.ToList();
        _filteredCount = list.Count;
        _filtered = list.AsQueryable();
    }

    private async Task Print() => await JS.InvokeVoidAsync("afcPrint", "");

    private async Task Show(ExecDrilldownDialog.Args args)
    {
        var parameters = new DialogParameters
        {
            Title = "Fit-Gap ▸ " + args.Title,
            Width = "720px",
            PrimaryAction = "Close",
            SecondaryAction = null
        };
        await DialogService.ShowDialogAsync<ExecDrilldownDialog>(args, parameters);
    }

    private async Task ShowFit(FitGap? fit, string title)
    {
        var rows = (fit is null ? _reqs : _reqs.Where(r => r.FitGap == fit)).OrderBy(r => r.Code).ToList();
        await Show(new ExecDrilldownDialog.Args
        {
            Title = title,
            Subtitle = $"{rows.Count} requirements · {rows.Sum(r => r.EffortDays):#,0} estimated effort days.",
            Kind = ExecDrilldownDialog.ChartKind.Bar,
            DatasetLabel = "Requirements",
            Labels = _fitLabels,
            Data = new decimal[] { _standard, _config, _custom, _isv },
            Headers = new[] { "Code", "Area", "Fit-Gap", "Effort" },
            Rows = rows.Select(r => new[] { r.Code, r.Area, r.FitGap.ToString(), $"{r.EffortDays}d" }).ToList()
        });
    }

    private async Task ShowFitBreakdown()
    {
        await Show(new ExecDrilldownDialog.Args
        {
            Title = "Fit vs. gap breakdown",
            Subtitle = $"{_fitPct:0.0}% fit (standard + configuration) vs. {(_custom + _isv)} gaps (customization + ISV).",
            Kind = ExecDrilldownDialog.ChartKind.Doughnut,
            DatasetLabel = "Requirements",
            Labels = _fitLabels,
            Data = new decimal[] { _standard, _config, _custom, _isv },
            Headers = new[] { "Category", "Count" },
            Rows = new List<string[]>
            {
                new[] { "Standard", _standard.ToString() },
                new[] { "Configuration", _config.ToString() },
                new[] { "Customization", _custom.ToString() },
                new[] { "ISV", _isv.ToString() }
            }
        });
    }

    private async Task ShowEffort()
    {
        var byArea = _areaLabels.Select((a, i) => new[] { a, $"{(int)_areaSeries[0].Data[i]:#,0}d" }).ToList();
        await Show(new ExecDrilldownDialog.Args
        {
            Title = "Effort by area",
            Subtitle = $"{_totalEffort:#,0} total estimated effort days across {_areas.Length} functional areas.",
            Kind = ExecDrilldownDialog.ChartKind.Bar,
            DatasetLabel = "Effort (days)",
            Labels = _areaLabels,
            Data = _areaSeries[0].Data.Select(v => (decimal)v).ToArray(),
            Headers = new[] { "Area", "Effort" },
            Rows = byArea
        });
    }

    private async Task OpenRequirement(Requirement? r)
    {
        if (r is null) return;
        var parameters = new DialogParameters
        {
            Title = $"Fit-Gap ▸ {r.Code} · {r.Area}",
            Width = "720px",
            PrimaryAction = "Close",
            SecondaryAction = null
        };
        await DialogService.ShowDialogAsync<RequirementDetailDialog>(r, parameters);
    }

    private static string FitGapKind(FitGap fg) => fg switch
    {
        FitGap.Standard => "good",
        FitGap.Configuration => "info",
        FitGap.Customization => "warn",
        FitGap.ISV => "neutral",
        _ => "neutral"
    };

    private async Task Export()
    {
        var headers = new[] { "Code", "Area", "Description", "Priority", "Process Area", "Fit-Gap", "Effort (days)", "Owner", "Status" };
        var rows = _reqs.Select(r => new[]
        {
            r.Code, r.Area, r.Description, r.Priority, r.ProcessArea, r.FitGap.ToString(), r.EffortDays.ToString(), r.Owner, r.Status
        });
        var csv = Csv.Build(headers, rows);
        await JS.InvokeVoidAsync("afcDownload", "fit-gap.csv", csv);
    }
}
