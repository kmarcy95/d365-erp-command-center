@page "/inventory"
@inject AppData AppData
@inject UiState Ui
@inject IJSRuntime JS
@inject IDialogService DialogService
<PageTitle>Inventory · D365 ERP Command Center</PageTitle>

<div class="print-only print-header">
    <div class="ph-co">Alamo Foods Co.</div>
    <div class="ph-report">Inventory — On-Hand &amp; Valuation</div>
    <div class="ph-meta">
        Fiscal period @Fiscal.PeriodLabel(AppData.Data.AsOf) · Currency @AppInfo.BaseCurrency ·
        Environment @Ui.EnvName · Generated @DateTime.Now.ToString("MMM d, yyyy h:mm tt")
    </div>
</div>

<div class="page-header">
    <div>
        <h1>Inventory</h1>
        <FluentBadge Appearance="Appearance.Accent" Class="persona-badge">D365 ERP Analyst</FluentBadge>
    </div>
    <div style="display:flex;gap:.5rem;align-items:center">
        <div class="scale-toggle" role="group" aria-label="Display units">
            <button class="@(_scale == MoneyScale.Units ? "is-active" : "")" @onclick="@(() => _scale = MoneyScale.Units)">$</button>
            <button class="@(_scale == MoneyScale.Thousands ? "is-active" : "")" @onclick="@(() => _scale = MoneyScale.Thousands)">$K</button>
            <button class="@(_scale == MoneyScale.Millions ? "is-active" : "")" @onclick="@(() => _scale = MoneyScale.Millions)">$M</button>
        </div>
        <FluentButton Appearance="Appearance.Stealth" OnClick="Print">🖨 Print / PDF</FluentButton>
        <FluentButton Appearance="Appearance.Accent" OnClick="Export">⬇ Export CSV</FluentButton>
    </div>
</div>

<PageMeta AsOf="@AppData.Data.AsOf" GeneratedAtUtc="@AppData.Data.GeneratedAtUtc" Module="Inventory management" />

<InventorySubnav Active="overview" />

@if (_error)
{
    <ErrorBanner Message="Couldn't load inventory data. Use the account menu in the header to reset the demo data." />
}
else if (!_ready)
{
    <Skeleton Variant="page" />
}
else
{
    <div class="kpi-grid">
        <KpiCard Label="Inventory Value" Value="@Fmt.Money(_totalValue, _scale)" Sub="@($"{_all.Count} SKUs on hand")"
                 Clickable="true" OnClick="ShowValueByCategory" />
        <KpiCard Label="Replenish Now" Value="@Fmt.Num(_replenishCount)" Sub="@($"~{Fmt.Money(_replenishValue, _scale)} suggested order")" Positive="@(_replenishCount == 0)"
                 Clickable="true" OnClick="ShowReplenish" />
        <KpiCard Label="Stockout Risk" Value="@Fmt.Num(_stockoutRisk)" Sub="Stocked out or below safety" Positive="@(_stockoutRisk == 0)"
                 Clickable="true" OnClick="ShowStockoutRisk" />
        <KpiCard Label="Excess / Obsolete" Value="@Fmt.Money(_excessValue, _scale)" Sub="@($"{_excessCount} SKUs > 120 days supply")" Positive="false"
                 Clickable="true" OnClick="ShowExcess" />
        <KpiCard Label="Avg Days of Supply" Value="@($"{_avgDaysOfSupply:0} days")" Sub="Weighted cover at avg usage"
                 Clickable="true" OnClick="ShowDaysOfSupply" />
        <KpiCard Label="Inventory Turns" Value="@($"{_turns:0.0}×")" Sub="Annualised usage ÷ on-hand"
                 Clickable="true" OnClick="ShowTurns" />
    </div>

    <div class="chart-grid">
        <Chart Title="Inventory value by category ($)" Type="doughnut" Labels="@_categoryLabels" Series="@_categorySeries"
               Hint="Click a slice to filter the table by category" OnLabelClick="OnCategoryPick" />
        <Chart Title="SKUs by stock health" Type="bar" Labels="@_stateLabels" Series="@_stateSeries"
               Hint="Click a bar to filter by stock health" OnLabelClick="OnStatePick" />
    </div>

    <div class="filter-bar">
        <div class="filter-field">
            <label>Category</label>
            <select value="@_category" @onchange="@(e => { _category = e.Value?.ToString() ?? ""; Apply(); })">
                <option value="">All categories</option>
                @foreach (var c in _categories) { <option value="@c">@c</option> }
            </select>
        </div>
        <div class="filter-field">
            <label>Warehouse</label>
            <select value="@_warehouse" @onchange="@(e => { _warehouse = e.Value?.ToString() ?? ""; Apply(); })">
                <option value="">All warehouses</option>
                @foreach (var w in _warehouses) { <option value="@w">@w</option> }
            </select>
        </div>
        <div class="filter-field">
            <label>Stock health</label>
            <select value="@_stock" @onchange="@(e => { _stock = e.Value?.ToString() ?? ""; Apply(); })">
                <option value="">All states</option>
                @foreach (var st in Enum.GetNames<StockState>()) { <option value="@st">@st</option> }
            </select>
        </div>
        <div class="filter-field">
            <label>ABC class</label>
            <select value="@_abc" @onchange="@(e => { _abc = e.Value?.ToString() ?? ""; Apply(); })">
                <option value="">All classes</option>
                <option value="A">A — top 80% value</option>
                <option value="B">B — next 15%</option>
                <option value="C">C — last 5%</option>
            </select>
        </div>
        <div class="filter-field" style="flex:1 1 160px">
            <label>Search</label>
            <input value="@_search" @oninput="@(e => { _search = e.Value?.ToString() ?? ""; Apply(); })" placeholder="Name or SKU…" />
        </div>
        <button class="fb-reset" @onclick="ResetFilters">Reset filters</button>
    </div>

    <div class="thr-legend">
        <span class="tl"><span class="sw sw-bad"></span> Stockout / critical (≤ safety stock)</span>
        <span class="tl"><span class="sw sw-warn"></span> Low — below reorder point</span>
        <span class="tl"><span class="sw" style="background:#e5f1fb"></span> Excess — &gt; 120 days supply</span>
    </div>

    <p class="grid-hint">@_filteredCount of @_all.Count SKUs shown · click any row for stock position, planning parameters &amp; a replenishment recommendation.</p>

    @if (_filteredCount == 0)
    {
        <div class="grid-wrap">
            <EmptyState Emoji="🏷️" Title="No matching items"
                        Message="No inventory items match the current filters. Try clearing a filter or resetting." />
        </div>
    }
    else
    {
        <div class="grid-wrap">
            <FluentDataGrid Items="@_filtered" Pagination="@_pagination" TGridItem="InventoryItem"
                            OnRowClick="@(async (FluentDataGridRow<InventoryItem> row) => await OpenItem(row.Item))"
                            RowClass="@RowClass">
                <PropertyColumn Property="@(i => i.Sku)" Title="SKU" Sortable="true" />
                <PropertyColumn Property="@(i => i.Name)" Title="Name" Sortable="true" />
                <PropertyColumn Property="@(i => i.Category)" Title="Category" Sortable="true" />
                <TemplateColumn Title="ABC" Sortable="true" Align="Align.Center"
                                SortBy="@(GridSort<InventoryItem>.ByAscending(i => i.AbcClass))">
                    <span class="abc-chip abc-@context.AbcClass">@context.AbcClass</span>
                </TemplateColumn>
                <PropertyColumn Property="@(i => i.OnHand)" Format="N0" Title="On hand" Sortable="true" Align="Align.End" />
                <PropertyColumn Property="@(i => i.ReorderPoint)" Format="N0" Title="Reorder pt" Sortable="true" Align="Align.End" />
                <TemplateColumn Title="Days supply" Align="Align.End"
                                SortBy="@(GridSort<InventoryItem>.ByAscending(i => i.DaysOfSupply))">
                    @(context.DaysOfSupply >= 999 ? "∞" : context.DaysOfSupply.ToString("0"))
                </TemplateColumn>
                <TemplateColumn Title="Suggest order" Align="Align.End"
                                SortBy="@(GridSort<InventoryItem>.ByAscending(i => i.SuggestedReorderQty))">
                    @(context.SuggestedReorderQty > 0 ? Fmt.Num(context.SuggestedReorderQty) : "—")
                </TemplateColumn>
                <TemplateColumn Title="Value ($)" Align="Align.End"
                                SortBy="@(GridSort<InventoryItem>.ByAscending(i => i.Value))">
                    @Fmt.Money(context.Value, _scale)
                </TemplateColumn>
                <TemplateColumn Title="Stock health" Sortable="false">
                    <StatusBadge Text="@context.State.ToString()" Kind="@StateKind(context.State)" />
                </TemplateColumn>
            </FluentDataGrid>
        </div>

        <FluentPaginator State="@_pagination" />
    }
}

@code {
    private bool _ready;
    private bool _error;
    private MoneyScale _scale = MoneyScale.Units;
    private string _search = "";
    private string _category = "";
    private string _warehouse = "";
    private string _stock = "";
    private string _abc = "";

    private List<InventoryItem> _all = new();
    private IQueryable<InventoryItem> _filtered = Enumerable.Empty<InventoryItem>().AsQueryable();
    private int _filteredCount;
    private readonly PaginationState _pagination = new() { ItemsPerPage = 15 };

    private decimal _totalValue;
    private int _replenishCount;
    private decimal _replenishValue;
    private int _stockoutRisk;
    private int _excessCount;
    private decimal _excessValue;
    private double _avgDaysOfSupply;
    private double _turns;
    private string[] _categories = Array.Empty<string>();
    private string[] _warehouses = Array.Empty<string>();

    private string[] _categoryLabels = Array.Empty<string>();
    private List<ChartSeries> _categorySeries = new();
    private static readonly StockState[] StateOrder = { StockState.Stockout, StockState.Critical, StockState.Low, StockState.Healthy, StockState.Excess };
    private string[] _stateLabels = Array.Empty<string>();
    private List<ChartSeries> _stateSeries = new();

    private static string StateKind(StockState s) => s switch
    {
        StockState.Stockout => "bad",
        StockState.Critical => "bad",
        StockState.Low => "warn",
        StockState.Excess => "info",
        _ => "good"
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await AppData.InitializeAsync();
            _all = AppData.Data.Inventory.ToList();

            // ABC classification by annualised usage value (cumulative 80 / 95 / 100).
            decimal totalUsage = _all.Sum(i => i.AnnualUsageValue);
            decimal cum = 0m;
            foreach (var i in _all.OrderByDescending(x => x.AnnualUsageValue))
            {
                cum += i.AnnualUsageValue;
                var pct = totalUsage == 0 ? 0 : cum / totalUsage * 100;
                i.AbcClass = pct <= 80 ? "A" : pct <= 95 ? "B" : "C";
            }

            _totalValue = _all.Sum(i => i.Value);
            _replenishCount = _all.Count(i => i.SuggestedReorderQty > 0);
            _replenishValue = _all.Sum(i => i.SuggestedReorderQty * i.UnitCost);
            _stockoutRisk = _all.Count(i => i.State is StockState.Stockout or StockState.Critical);
            var excess = _all.Where(i => i.State == StockState.Excess).ToList();
            _excessCount = excess.Count;
            _excessValue = excess.Sum(i => i.Value);
            _avgDaysOfSupply = _all.Count == 0 ? 0 : _all.Average(i => Math.Min(i.DaysOfSupply, 365));
            _turns = _totalValue <= 0 ? 0 : (double)(_all.Sum(i => i.AnnualUsageValue) / _totalValue);

            _categories = _all.Select(i => i.Category).Distinct().OrderBy(x => x).ToArray();
            _warehouses = _all.Select(i => i.WarehouseCode).Distinct().OrderBy(x => x).ToArray();

            var byCategory = _all
                .GroupBy(i => i.Category)
                .Select(g => new { Category = g.Key, Value = g.Sum(i => i.Value) })
                .OrderByDescending(g => g.Value)
                .ToList();
            _categoryLabels = byCategory.Select(g => g.Category).ToArray();
            _categorySeries = new List<ChartSeries>
            {
                new ChartSeries("Value", byCategory.Select(g => (double)g.Value).ToArray())
            };

            _stateLabels = StateOrder.Select(s => s.ToString()).ToArray();
            _stateSeries = new List<ChartSeries>
            {
                new ChartSeries("SKUs", StateOrder.Select(s => (double)_all.Count(i => i.State == s)).ToArray())
            };

            Apply();
            _ready = true;
        }
        catch
        {
            _error = true;
        }
    }

    private string RowClass(InventoryItem i) => i.State switch
    {
        StockState.Stockout or StockState.Critical => "grid-row-clickable var-row-bad",
        StockState.Low => "grid-row-clickable var-row-warn",
        _ => "grid-row-clickable"
    };

    private void ResetFilters()
    {
        _search = _category = _warehouse = _stock = _abc = "";
        Apply();
    }

    // Chart→table: clicking a chart label sets (or toggles off) the matching filter.
    private void OnCategoryPick(string c) { _category = _category == c ? "" : c; Apply(); }
    private void OnStatePick(string s) { _stock = _stock == s ? "" : s; Apply(); }

    private void Apply()
    {
        var q = _all.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(_category)) q = q.Where(i => i.Category == _category);
        if (!string.IsNullOrWhiteSpace(_warehouse)) q = q.Where(i => i.WarehouseCode == _warehouse);
        if (!string.IsNullOrWhiteSpace(_stock)) q = q.Where(i => i.State.ToString() == _stock);
        if (!string.IsNullOrWhiteSpace(_abc)) q = q.Where(i => i.AbcClass == _abc);
        if (!string.IsNullOrWhiteSpace(_search))
        {
            var s = _search.Trim();
            q = q.Where(i =>
                i.Name.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                i.Sku.Contains(s, StringComparison.OrdinalIgnoreCase));
        }
        var list = q.ToList();
        _filteredCount = list.Count;
        _filtered = list.AsQueryable();
    }

    private async Task Print() => await JS.InvokeVoidAsync("afcPrint", "");

    // ---------------- Drill-down dialogs (with breadcrumb in title) ----------------

    private async Task ShowDrilldown(InventoryDrilldownDialog.Args args)
    {
        var parameters = new DialogParameters
        {
            Title = "Inventory ▸ " + args.Title,
            Width = "780px",
            PrimaryAction = "Close",
            SecondaryAction = null
        };
        await DialogService.ShowDialogAsync<InventoryDrilldownDialog>(args, parameters);
    }

    private async Task ShowValueByCategory()
    {
        var groups = _all.GroupBy(i => i.Category)
            .Select(g => new { Category = g.Key, Value = g.Sum(i => i.Value) })
            .OrderByDescending(g => g.Value)
            .ToList();
        await ShowDrilldown(new InventoryDrilldownDialog.Args
        {
            Title = "Inventory Value by Category",
            Subtitle = $"{Fmt.Money(_totalValue)} on hand across {_all.Count} SKUs.",
            Items = _all,
            Kind = InventoryDrilldownDialog.ChartKind.Bar,
            DatasetLabel = "Value ($)",
            Labels = groups.Select(g => g.Category).ToArray(),
            Data = groups.Select(g => g.Value).ToArray(),
            MoneyAxis = true
        });
    }

    private async Task ShowReplenish()
    {
        var items = _all.Where(i => i.SuggestedReorderQty > 0).OrderByDescending(i => i.SuggestedReorderQty * i.UnitCost).ToList();
        var groups = items.GroupBy(i => i.Category)
            .Select(g => new { Cat = g.Key, Cost = g.Sum(i => i.SuggestedReorderQty * i.UnitCost) })
            .OrderByDescending(g => g.Cost).ToList();
        await ShowDrilldown(new InventoryDrilldownDialog.Args
        {
            Title = "Replenishment Recommendation",
            Subtitle = $"{items.Count} SKUs below reorder + safety — suggested order ≈ {Fmt.Money(_replenishValue)}, by category.",
            Items = items,
            Kind = InventoryDrilldownDialog.ChartKind.Bar,
            DatasetLabel = "Suggested order ($)",
            Labels = groups.Select(g => g.Cat).ToArray(),
            Data = groups.Select(g => g.Cost).ToArray(),
            MoneyAxis = true
        });
    }

    private async Task ShowStockoutRisk()
    {
        var items = _all.Where(i => i.State is StockState.Stockout or StockState.Critical).OrderBy(i => i.DaysOfSupply).ToList();
        var byCat = items.GroupBy(i => i.Category).OrderByDescending(g => g.Count()).ToList();
        await ShowDrilldown(new InventoryDrilldownDialog.Args
        {
            Title = "Stockout & Critical-Stock Risk",
            Subtitle = $"{items.Count} SKUs are stocked out or at/below safety stock — by category.",
            Items = items,
            Kind = InventoryDrilldownDialog.ChartKind.Bar,
            DatasetLabel = "At-risk SKUs",
            Labels = byCat.Select(g => g.Key).ToArray(),
            Data = byCat.Select(g => (decimal)g.Count()).ToArray()
        });
    }

    private async Task ShowExcess()
    {
        var items = _all.Where(i => i.State == StockState.Excess).OrderByDescending(i => i.Value).ToList();
        var byCat = items.GroupBy(i => i.Category)
            .Select(g => new { Cat = g.Key, Value = g.Sum(i => i.Value) })
            .OrderByDescending(g => g.Value).ToList();
        await ShowDrilldown(new InventoryDrilldownDialog.Args
        {
            Title = "Excess / Obsolete Stock",
            Subtitle = $"{_excessCount} SKUs hold > 120 days of supply, tying up {Fmt.Money(_excessValue)} — by category.",
            Items = items,
            Kind = InventoryDrilldownDialog.ChartKind.Bar,
            DatasetLabel = "Excess value ($)",
            Labels = byCat.Select(g => g.Cat).ToArray(),
            Data = byCat.Select(g => g.Value).ToArray(),
            MoneyAxis = true
        });
    }

    private async Task ShowDaysOfSupply()
    {
        var byCat = _all.GroupBy(i => i.Category)
            .Select(g => new { Cat = g.Key, Days = g.Average(i => Math.Min(i.DaysOfSupply, 365)) })
            .OrderByDescending(g => g.Days).ToList();
        await ShowDrilldown(new InventoryDrilldownDialog.Args
        {
            Title = "Days of Supply by Category",
            Subtitle = $"Weighted average cover is ~{_avgDaysOfSupply:0} days at current usage rates.",
            Items = _all,
            Kind = InventoryDrilldownDialog.ChartKind.Bar,
            DatasetLabel = "Avg days of supply",
            Labels = byCat.Select(g => g.Cat).ToArray(),
            Data = byCat.Select(g => (decimal)Math.Round(g.Days, 0)).ToArray()
        });
    }

    private async Task ShowTurns()
    {
        var byCat = _all.GroupBy(i => i.Category)
            .Select(g => new { Cat = g.Key, Turns = g.Sum(i => i.AnnualUsageValue) / (g.Sum(i => i.Value) == 0 ? 1 : g.Sum(i => i.Value)) })
            .OrderByDescending(g => g.Turns).ToList();
        await ShowDrilldown(new InventoryDrilldownDialog.Args
        {
            Title = "Inventory Turns by Category",
            Subtitle = $"Portfolio turns ≈ {_turns:0.0}× per year (annualised usage ÷ on-hand value).",
            Items = _all,
            Kind = InventoryDrilldownDialog.ChartKind.Bar,
            DatasetLabel = "Turns (×/yr)",
            Labels = byCat.Select(g => g.Cat).ToArray(),
            Data = byCat.Select(g => Math.Round(g.Turns, 1)).ToArray()
        });
    }

    private async Task OpenItem(InventoryItem? item)
    {
        if (item is null) return;
        var parameters = new DialogParameters
        {
            Title = $"Inventory ▸ {item.Sku} · {item.Name}",
            Width = "640px",
            PrimaryAction = "Close",
            SecondaryAction = null
        };
        await DialogService.ShowDialogAsync<InventoryItemDetailDialog>(item, parameters);
    }

    private async Task Export()
    {
        var headers = new[] { "Sku", "Name", "Category", "Warehouse", "AbcClass", "OnHand", "ReorderPoint", "SafetyStock",
            "AvgDailyUsage", "LeadTimeDays", "DaysOfSupply", "SuggestedReorderQty", "UnitCost", "UnitPrice", "Value", "AnnualUsageValue", "Turns", "StockState" };
        var rows = _all.Select(i => new[]
        {
            i.Sku,
            i.Name,
            i.Category,
            i.WarehouseCode,
            i.AbcClass,
            i.OnHand.ToString(),
            i.ReorderPoint.ToString(),
            i.SafetyStock.ToString(),
            i.AvgDailyUsage.ToString("0.0"),
            i.LeadTimeDays.ToString(),
            i.DaysOfSupply.ToString("0.0"),
            i.SuggestedReorderQty.ToString(),
            i.UnitCost.ToString("0.##"),
            i.UnitPrice.ToString("0.##"),
            i.Value.ToString("0.##"),
            i.AnnualUsageValue.ToString("0.##"),
            i.Turns.ToString("0.0"),
            i.State.ToString()
        });
        var csv = Csv.Build(headers, rows);
        await JS.InvokeVoidAsync("afcDownload", "inventory.csv", csv);
    }
}
