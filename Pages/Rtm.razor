@page "/rtm"
@inject AppData AppData
@inject UiState Ui
@inject IJSRuntime JS
@inject IDialogService DialogService
<PageTitle>Requirements Traceability Matrix · D365 ERP Command Center</PageTitle>

<div class="print-only print-header">
    <div class="ph-co">Alamo Foods Co.</div>
    <div class="ph-report">Requirements Traceability Matrix — requirements ↔ test coverage</div>
    <div class="ph-meta">
        As of @AppData.Data.AsOf.ToString("MMM d, yyyy") · Environment @Ui.EnvName ·
        Generated @DateTime.Now.ToString("MMM d, yyyy h:mm tt")
    </div>
</div>

<div class="page-header">
    <div>
        <h1>Requirements Traceability Matrix</h1>
        <FluentBadge Appearance="Appearance.Accent" Class="persona-badge">Business Analyst</FluentBadge>
    </div>
    <FluentButton Appearance="Appearance.Accent" OnClick="Export">⬇ Export CSV</FluentButton>
</div>

<PageMeta AsOf="@AppData.Data.AsOf" GeneratedAtUtc="@AppData.Data.GeneratedAtUtc" Module="Implementation · Traceability" />

@if (_error)
{
    <ErrorBanner Message="Couldn't load the traceability matrix. Use the account menu in the header to reset the demo data." />
}
else if (!_ready)
{
    <Skeleton Variant="page" />
}
else
{
    <div class="kpi-grid">
        <KpiCard Label="Requirements" Value="@Fmt.Num(_reqs.Count)" Sub="Total catalogued"
                 Clickable="true" OnClick="@(() => ShowStatus(null, "All requirements"))" />
        <KpiCard Label="With Tests" Value="@Fmt.Num(_withTests)" Sub="≥ 1 linked test case"
                 Clickable="true" OnClick="ShowCoverage" />
        <KpiCard Label="Coverage" Value="@Fmt.Pct(_coverage)" Sub="Requirements traced to tests"
                 Clickable="true" OnClick="ShowCoverage" />
        <KpiCard Label="Failing" Value="@Fmt.Num(_failing)" Sub="≥ 1 failed test" Positive="false"
                 Clickable="true" OnClick="@(() => ShowStatus("Fail", "Failing requirements"))" />
    </div>

    <div class="chart-grid">
        <Chart Title="Test status by requirement" Type="doughnut" Labels="@_statusLabels" Series="@_statusSeries"
               Hint="Click a slice to filter the matrix" OnLabelClick="OnStatusPick" />
        <Chart Title="Coverage by area" Type="bar" Labels="@_areaLabels" Series="@_areaSeries" Stacked="true"
               Hint="Click a bar to filter by area" OnLabelClick="OnAreaPick" />
    </div>

    <div class="filter-bar">
        <div class="filter-field">
            <label>Area</label>
            <select value="@_area" @onchange="@(e => { _area = e.Value?.ToString() ?? ""; Apply(); })">
                <option value="">All areas</option>
                @foreach (var a in _areas) { <option value="@a">@a</option> }
            </select>
        </div>
        <div class="filter-field">
            <label>Process</label>
            <select value="@_process" @onchange="@(e => { _process = e.Value?.ToString() ?? ""; Apply(); })">
                <option value="">All</option>
                @foreach (var p in _processes) { <option value="@p">@p</option> }
            </select>
        </div>
        <div class="filter-field">
            <label>Test status</label>
            <select value="@_status" @onchange="@(e => { _status = e.Value?.ToString() ?? ""; Apply(); })">
                <option value="">All</option>
                <option value="Pass">Pass</option>
                <option value="Fail">Fail</option>
                <option value="Not Run">Not Run</option>
            </select>
        </div>
        <div class="filter-field" style="flex:1 1 180px">
            <label>Search</label>
            <input value="@_search" @oninput="@(e => { _search = e.Value?.ToString() ?? ""; Apply(); })" placeholder="Code or description…" />
        </div>
        <button class="fb-reset" @onclick="ResetFilters">Reset filters</button>
    </div>

    <p class="grid-hint">@_filteredCount of @_reqs.Count requirements shown · click any requirement to trace it to its test cases.</p>

    @if (_filteredCount == 0)
    {
        <div class="grid-wrap">
            <EmptyState Emoji="🔗" Title="No matching requirements"
                        Message="No requirements match the current filters. Try clearing a filter or resetting." />
        </div>
    }
    else
    {
        <div class="grid-wrap">
            <FluentDataGrid Items="@_filtered" Pagination="@_pagination" TGridItem="Requirement"
                            OnRowClick="@(async (FluentDataGridRow<Requirement> row) => await OpenRequirement(row.Item))"
                            RowClass="@(_ => "grid-row-clickable")">
                <PropertyColumn Property="@(r => r.Code)" Title="Code" Sortable="true" />
                <PropertyColumn Property="@(r => r.Area)" Title="Area" Sortable="true" />
                <PropertyColumn Property="@(r => r.ProcessArea)" Title="Process" Sortable="true" />
                <PropertyColumn Property="@(r => r.Description)" Title="Description" />
                <TemplateColumn Title="Fit-Gap" Sortable="true">
                    <StatusBadge Text="@context.FitGap.ToString()" Kind="@FitGapKind(context.FitGap)" />
                </TemplateColumn>
                <TemplateColumn Title="Tests" Align="Align.End">@TestCountFor(context.Code)</TemplateColumn>
                <TemplateColumn Title="Test status">
                    @{ var ts = TestStatusFor(context.Code); }
                    <StatusBadge Text="@ts" Kind="@TestKind(ts)" />
                </TemplateColumn>
            </FluentDataGrid>
        </div>
        <FluentPaginator State="@_pagination" />
    }
}

@code {
    private bool _ready;
    private bool _error;
    private string _search = "", _area = "", _process = "", _status = "";

    private List<Requirement> _reqs = new();
    private List<TestCase> _tests = new();
    private IQueryable<Requirement> _filtered = Enumerable.Empty<Requirement>().AsQueryable();
    private int _filteredCount;
    private readonly PaginationState _pagination = new() { ItemsPerPage = 15 };

    private int _withTests;
    private decimal _coverage;
    private int _failing;

    private string[] _areas = Array.Empty<string>();
    private string[] _processes = Array.Empty<string>();

    private string[] _statusLabels = Array.Empty<string>();
    private List<ChartSeries> _statusSeries = new();
    private string[] _areaLabels = Array.Empty<string>();
    private List<ChartSeries> _areaSeries = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await AppData.InitializeAsync();
            _reqs = AppData.Data.Requirements.ToList();
            _tests = AppData.Data.TestCases.ToList();

            _withTests = _reqs.Count(r => _tests.Any(t => t.RequirementCode == r.Code));
            _coverage = _reqs.Count == 0 ? 0m : (decimal)_withTests / _reqs.Count * 100m;
            _failing = _reqs.Count(r => TestStatusFor(r.Code) == "Fail");

            _areas = _reqs.Select(r => r.Area).Distinct().OrderBy(a => a).ToArray();
            _processes = _reqs.Select(r => r.ProcessArea).Distinct().OrderBy(p => p).ToArray();

            int pass = _reqs.Count(r => TestStatusFor(r.Code) == "Pass");
            int fail = _failing;
            int notRun = _reqs.Count - pass - fail;
            _statusLabels = new[] { "Pass", "Fail", "Not Run" };
            _statusSeries = new List<ChartSeries> { new ChartSeries("Requirements", new double[] { pass, fail, notRun }) };

            // Stacked coverage: covered vs uncovered per area.
            var covered = _areas.Select(a => (double)_reqs.Count(r => r.Area == a && _tests.Any(t => t.RequirementCode == r.Code))).ToArray();
            var uncovered = _areas.Select(a => (double)_reqs.Count(r => r.Area == a && !_tests.Any(t => t.RequirementCode == r.Code))).ToArray();
            _areaLabels = _areas;
            _areaSeries = new List<ChartSeries>
            {
                new ChartSeries("Covered", covered, "#16a34a"),
                new ChartSeries("Uncovered", uncovered, "#d13438")
            };

            Apply();
            _ready = true;
        }
        catch
        {
            _error = true;
        }
    }

    private void ResetFilters() { _search = _area = _process = _status = ""; Apply(); }
    private void OnStatusPick(string s) { _status = _status == s ? "" : s; Apply(); }
    private void OnAreaPick(string a) { _area = _area == a ? "" : a; Apply(); }

    private void Apply()
    {
        var q = _reqs.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(_area)) q = q.Where(r => r.Area == _area);
        if (!string.IsNullOrWhiteSpace(_process)) q = q.Where(r => r.ProcessArea == _process);
        if (!string.IsNullOrWhiteSpace(_status)) q = q.Where(r => TestStatusFor(r.Code) == _status);
        if (!string.IsNullOrWhiteSpace(_search))
        {
            var s = _search.Trim();
            q = q.Where(r => r.Code.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                             r.Description.Contains(s, StringComparison.OrdinalIgnoreCase));
        }
        var list = q.ToList();
        _filteredCount = list.Count;
        _filtered = list.AsQueryable();
    }

    private int TestCountFor(string code) => _tests.Count(t => t.RequirementCode == code);

    private string TestStatusFor(string code)
    {
        var linked = _tests.Where(t => t.RequirementCode == code).ToList();
        if (linked.Count == 0) return "Not Run";
        if (linked.Any(t => t.Result == TestResult.Fail)) return "Fail";
        if (linked.All(t => t.Result == TestResult.Pass)) return "Pass";
        return "Not Run";
    }

    private static string TestKind(string status) => status switch
    {
        "Pass" => "good",
        "Fail" => "bad",
        _ => "neutral"
    };

    private static string FitGapKind(FitGap fg) => fg switch
    {
        FitGap.Standard => "good",
        FitGap.Configuration => "info",
        FitGap.Customization => "warn",
        FitGap.ISV => "neutral",
        _ => "neutral"
    };

    private async Task Show(ExecDrilldownDialog.Args args)
    {
        var parameters = new DialogParameters
        {
            Title = "Traceability ▸ " + args.Title,
            Width = "720px",
            PrimaryAction = "Close",
            SecondaryAction = null
        };
        await DialogService.ShowDialogAsync<ExecDrilldownDialog>(args, parameters);
    }

    private async Task ShowStatus(string? status, string title)
    {
        var rows = (status is null ? _reqs : _reqs.Where(r => TestStatusFor(r.Code) == status)).OrderBy(r => r.Code).ToList();
        await Show(new ExecDrilldownDialog.Args
        {
            Title = title,
            Subtitle = $"{rows.Count} requirements · {_coverage:0.0}% overall test coverage.",
            Kind = ExecDrilldownDialog.ChartKind.Doughnut,
            DatasetLabel = "Requirements",
            Labels = _statusLabels,
            Data = _statusSeries[0].Data.Select(v => (decimal)v).ToArray(),
            Headers = new[] { "Code", "Area", "Tests", "Status" },
            Rows = rows.Select(r => new[] { r.Code, r.Area, TestCountFor(r.Code).ToString(), TestStatusFor(r.Code) }).ToList()
        });
    }

    private async Task ShowCoverage()
    {
        var rows = _areas.Select(a =>
        {
            int total = _reqs.Count(r => r.Area == a);
            int cov = _reqs.Count(r => r.Area == a && _tests.Any(t => t.RequirementCode == r.Code));
            return new[] { a, $"{cov}/{total}", total == 0 ? "—" : $"{(decimal)cov / total * 100m:0.0}%" };
        }).ToList();
        await Show(new ExecDrilldownDialog.Args
        {
            Title = "Coverage by area",
            Subtitle = $"{_withTests} of {_reqs.Count} requirements traced to at least one test ({_coverage:0.0}%).",
            Kind = ExecDrilldownDialog.ChartKind.Bar,
            DatasetLabel = "Covered",
            Labels = _areaLabels,
            Data = _areaSeries[0].Data.Select(v => (decimal)v).ToArray(),
            Headers = new[] { "Area", "Covered", "Coverage %" },
            Rows = rows
        });
    }

    private async Task OpenRequirement(Requirement? r)
    {
        if (r is null) return;
        var parameters = new DialogParameters
        {
            Title = $"Traceability ▸ {r.Code} · {r.Area}",
            Width = "720px",
            PrimaryAction = "Close",
            SecondaryAction = null
        };
        await DialogService.ShowDialogAsync<RequirementDetailDialog>(r, parameters);
    }

    private async Task Export()
    {
        var headers = new[] { "Code", "Area", "Process Area", "Description", "Fit-Gap", "Test count", "Test status" };
        var rows = _reqs.Select(r => new[]
        {
            r.Code, r.Area, r.ProcessArea, r.Description, r.FitGap.ToString(), TestCountFor(r.Code).ToString(), TestStatusFor(r.Code)
        });
        var csv = Csv.Build(headers, rows);
        await JS.InvokeVoidAsync("afcDownload", "rtm.csv", csv);
    }
}
